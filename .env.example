# Copy this file to `backend/.env` and fill in real values.
# See backend/.env.example for the full list of variables and comments.

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=amity_leads
CORS_ORIGINS=http://localhost:5173

# App login (Flask UI)
# Username/password pairs are fixed as: admin/Admin123 and caller/Caller123.
# Set these only if you want to override the defaults in app.py.
ADMIN_PASSWORD=Admin123
CALLER_PASSWORD=Caller123

PORTAL_URL=https://your-portal.example.com
PORTAL_USERNAME=you@example.com
PORTAL_PASSWORD=change-me

SCRAPER_SEARCH_PAGE_URL=https://your-portal.example.com/search
PLAYWRIGHT_USER_DATA_DIR=./data/playwright_profile

# Flask portal scraper (app.py): set false to watch the browser; row highlights need a visible window.
SCRAPER_HEADLESS=true
# Random pause (uniform) after navigation / login / between dates — default 3–8s to reduce rate-limit flags.
# SCRAPER_MIN_DELAY_SEC=3
# SCRAPER_MAX_DELAY_SEC=8
# auto = highlight rows only when headless is false; true = always use slow row-by-row read with highlight
SCRAPER_HIGHLIGHT_ROWS=auto
SCRAPER_ROW_HIGHLIGHT_PAUSE_SEC=0.055
# If the LMS table never fills, try false (disables image/font/media blocking in Playwright).
SCRAPER_BLOCK_HEAVY_RESOURCES=true

# Scheduled scrape (cron_scrape.py): defaults are Asia/Kolkata + data/.scraper_cron.lock in app.py.
# SCRAPER_CRON_TZ=Asia/Kolkata
# SCRAPER_CRON_START_DATE=2026-05-01
# SCRAPER_CRON_LOCK_PATH=
# When true (default), cron_scrape.py forces SCRAPER_HEADLESS=true so Task Scheduler can run without a desktop.
# SCRAPER_CRON_USE_HEADLESS=true

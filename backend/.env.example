# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=amity_leads

# CORS: React dev UI (open http://localhost:5173). Comma-separate to add more local origins.
CORS_ORIGINS=http://localhost:5173

# --- Portal credentials (server-side only; never expose to frontend) ---
PORTAL_URL=https://your-portal.example.com
# Optional overrides:
# PORTAL_LOGIN_URL=https://your-portal.example.com/account/login
PORTAL_USERNAME=you@example.com
PORTAL_PASSWORD=change-me

# Playwright persistent profile (cookies/localStorage survive restarts)
PLAYWRIGHT_USER_DATA_DIR=./data/playwright_profile
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=60000
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY_SEC=2.0

# After login, full URL to the "Search Data" (or equivalent) screen
SCRAPER_SEARCH_PAGE_URL=https://your-portal.example.com/path/to/search
SCRAPER_POST_LOGIN_WAIT_MS=1500

# Comma-separated CSS selectors (first match wins)
SCRAPER_EMAIL_SELECTOR=input[type="email"],input[name="email"],#email
SCRAPER_PASSWORD_SELECTOR=input[type="password"],#password
SCRAPER_LOGIN_SUBMIT_SELECTOR=button[type="submit"],button:has-text("Login")

SCRAPER_DATE_INPUT_SELECTOR=input[type="date"],input[name="date"]
SCRAPER_SEARCH_BUTTON_SELECTOR=button:has-text("Search"),input[value="Search"]
SCRAPER_RESULTS_TABLE_SELECTOR=table
SCRAPER_RESULTS_ROW_SELECTOR=tbody tr
SCRAPER_NEXT_PAGE_SELECTOR=a:has-text("Next"),button:has-text("Next")

# Daily cron (when auto sync is enabled in GET/PATCH /settings/sync)
AUTO_SYNC_CRON_HOUR=6
AUTO_SYNC_CRON_MINUTE=0
# If true, scheduled job uses yesterday's date instead of today
AUTO_SYNC_USE_YESTERDAY=false
